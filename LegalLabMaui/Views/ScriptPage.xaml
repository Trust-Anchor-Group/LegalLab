<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:script="clr-namespace:LegalLabMaui.Models.Script"
             x:Class="LegalLabMaui.Views.ScriptPage"
             x:DataType="script:ScriptModel"
             Title="Script">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- History / output area -->
        <CollectionView Grid.Row="0"
                        x:Name="HistoryCollectionView"
                        ItemsSource="{Binding History}"
                        SelectionMode="Single"
                        SelectionChanged="HistoryCollectionView_SelectionChanged"
                        Margin="0,0,0,4">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical"
                                   ItemSpacing="8"/>
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="script:ScriptHistoryItem">
                    <Border StrokeThickness="1"
                            Stroke="{Binding CardStroke}"
                            StrokeShape="RoundRectangle 10"
                            BackgroundColor="{Binding CardBackground}"
                            Padding="12"
                            Margin="8,8,8,0">
                        <VerticalStackLayout Spacing="8">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Text="{Binding HeaderText}"
                                       TextColor="#5F6B7A"
                                       FontSize="11"
                                       FontAttributes="Bold"
                                       CharacterSpacing="0.4"/>
                                <Border Grid.Column="1"
                                        BackgroundColor="{Binding StatusBadgeBackground}"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 999"
                                        Padding="8,2">
                                    <Label Text="{Binding StatusText}"
                                           TextColor="{Binding StatusBadgeTextColor}"
                                           FontSize="11"
                                           FontAttributes="Bold"/>
                                </Border>
                            </Grid>
                            <Label Text="{Binding Script}"
                                   FontFamily="Courier New"
                                   FontSize="13"
                                   LineBreakMode="WordWrap"
                                   TextColor="#17212B"/>
                            <BoxView HeightRequest="1"
                                     Color="#D7DEE7"/>
                            <Label Text="{Binding Result}"
                                   FontFamily="Courier New"
                                   FontSize="13"
                                   LineBreakMode="WordWrap"
                                   TextColor="{Binding ResultTextColor}"/>
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Input area -->
        <VerticalStackLayout Grid.Row="1"
                             Padding="8"
                             Spacing="4">
            <Label FontSize="12">
                <Label.FormattedText>
                    <FormattedString>
                        <Span Text="Enter script below. Use Ctrl+Enter to run on Windows, or the Run button. Script reference: "/>
                        <Span Text="{Binding ReferenceUri}"
                              TextDecorations="Underline"
                              TextColor="Blue"/>
                    </FormattedString>
                </Label.FormattedText>
            </Label>
            <Editor x:Name="InputEdit"
                    Text="{Binding Input}"
                    AutoSize="TextChanges"
                    MinimumHeightRequest="80"
                    MaximumHeightRequest="180"
                    Placeholder="Enter script to execute here."
                    HorizontalOptions="Fill"/>
            <Button Text="Run"
                    x:Name="RunButton"
                    Command="{Binding Run}"
                    HorizontalOptions="End"
                    WidthRequest="100"/>
        </VerticalStackLayout>
    </Grid>
</ContentPage>
