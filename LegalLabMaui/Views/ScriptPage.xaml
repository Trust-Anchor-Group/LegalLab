<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LegalLabMaui.Views.ScriptPage"
             Title="Script">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- History / output area -->
        <ScrollView Grid.Row="0" x:Name="HistoryScrollView">
            <VerticalStackLayout x:Name="HistoryPanel" Padding="8" Spacing="4"/>
        </ScrollView>

        <!-- Input area -->
        <VerticalStackLayout Grid.Row="1" Padding="8" Spacing="4">
            <Label FontSize="12">
                <Label.FormattedText>
                    <FormattedString>
                        <Span Text="Enter script to execute below. Execute by pressing the Run button. Script reference: "/>
                        <Span Text="{Binding ReferenceUri}" TextDecorations="Underline" TextColor="Blue"/>
                    </FormattedString>
                </Label.FormattedText>
            </Label>
            <Editor x:Name="InputEdit"
                    Text="{Binding Input, UpdateSourceTrigger=PropertyChanged}"
                    AutoSize="TextChanges"
                    MinimumHeightRequest="60"
                    MaximumHeightRequest="120"
                    Placeholder="Enter script to execute here."
                    HorizontalOptions="Fill"/>
            <Button Text="Run" Command="{Binding Execute}"
                    HorizontalOptions="End" WidthRequest="100"/>
        </VerticalStackLayout>
    </Grid>
</ContentPage>
