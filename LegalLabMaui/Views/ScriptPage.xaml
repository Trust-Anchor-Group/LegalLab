<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:script="clr-namespace:LegalLabMaui.Models.Script"
             x:Class="LegalLabMaui.Views.ScriptPage"
             x:DataType="script:ScriptModel"
             Title="Script">
    <Grid Padding="24,20,24,28"
          RowDefinitions="Auto,*,Auto"
          RowSpacing="18">
        <Border Grid.Row="1"
                Style="{StaticResource SectionCardStyle}">
            <VerticalStackLayout Spacing="14">
                <Label Text="Script Console"
                       Style="{StaticResource PageTitleStyle}" />
                <CollectionView x:Name="HistoryCollectionView"
                                ItemsSource="{Binding History}"
                                SelectionMode="Single"
                                SelectionChanged="HistoryCollectionView_SelectionChanged"
                                ItemsUpdatingScrollMode="KeepItemsInView">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical"
                                           ItemSpacing="8"/>
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="script:ScriptHistoryItem">
                            <Border StrokeThickness="1"
                                    Stroke="{Binding CardStroke}"
                                    StrokeShape="RoundRectangle 10"
                                    BackgroundColor="{Binding CardBackground}"
                                    Padding="12">
                                <VerticalStackLayout Spacing="8">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label Text="{Binding HeaderText}"
                                               TextColor="{StaticResource TextMuted}"
                                               FontSize="11"
                                               FontAttributes="Bold"
                                               CharacterSpacing="0.4"/>
                                        <Border Grid.Column="1"
                                                BackgroundColor="{Binding StatusBadgeBackground}"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 999"
                                                Padding="8,2">
                                            <Label Text="{Binding StatusText}"
                                                   TextColor="{Binding StatusBadgeTextColor}"
                                                   FontSize="11"
                                                   FontAttributes="Bold"/>
                                        </Border>
                                    </Grid>
                                    <Label Text="{Binding Script}"
                                           Style="{StaticResource MonoLabelStyle}"
                                           LineBreakMode="WordWrap"/>
                                    <BoxView Style="{StaticResource DividerStyle}"/>
                                    <Label Text="{Binding Result}"
                                           FontFamily="Courier New"
                                           FontSize="13"
                                           LineBreakMode="WordWrap"
                                           TextColor="{Binding ResultTextColor}"/>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </Border>

        <Border Grid.Row="2"
                Style="{StaticResource SectionCardStyle}">
            <VerticalStackLayout Spacing="10">
                <Label Text="Run Script"
                       Style="{StaticResource SectionTitleStyle}"/>
                <Label FontSize="12"
                       Style="{StaticResource SectionCaptionStyle}">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="Script reference: "/>
                            <Span Text="{Binding ReferenceUri}"
                                  TextDecorations="Underline"
                                  TextColor="{StaticResource Primary}"/>
                        </FormattedString>
                    </Label.FormattedText>
                </Label>
                <Editor x:Name="InputEdit"
                        Text="{Binding Input}"
                        Style="{StaticResource MonoEditorStyle}"
                        MinimumHeightRequest="120"
                        MaximumHeightRequest="220"
                        Placeholder="Enter script to execute here."
                        HorizontalOptions="Fill"/>
                <Button Text="Run"
                        x:Name="RunButton"
                        Command="{Binding Run}"
                        HorizontalOptions="End"
                        WidthRequest="120"/>
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>
