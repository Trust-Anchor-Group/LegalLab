<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:conv="clr-namespace:LegalLabMaui.Converters"
             x:Class="LegalLabMaui.Views.WalletPage"
             Title="Wallet">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Left: Wallet summary and actions -->
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="16" Spacing="6">
                <Label Text="Balance:"/>
                <Entry Text="{Binding Amount, Converter={conv:MoneyToString}}" IsReadOnly="True"/>

                <Label Text="Reserved:" Margin="0,8,0,0"/>
                <Entry Text="{Binding Reserved, Converter={conv:MoneyToString}}" IsReadOnly="True"/>

                <Label Text="Pending: (i.e. Offline payments)" Margin="0,8,0,0"/>
                <Entry Text="{Binding Pending, Converter={conv:MoneyToString}}" IsReadOnly="True"/>

                <Label Text="Available:" Margin="0,8,0,0"/>
                <Entry Text="{Binding Available, Converter={conv:MoneyToString}}" IsReadOnly="True"/>

                <Label Text="Currency:" Margin="0,8,0,0"/>
                <Entry Text="{Binding Currency}" IsReadOnly="True"/>

                <Label Text="Timestamp:" Margin="0,8,0,0"/>
                <Entry Text="{Binding Timestamp, Converter={conv:DateTimeToString}}" IsReadOnly="True"/>

                <BoxView HeightRequest="1" Color="Black" Margin="20,16"/>

                <Label Text="e-Daler URI:"/>
                <Editor Text="{Binding Uri}" AutoSize="TextChanges" MinimumHeightRequest="80"/>
                <Button Text="Send URI" Command="{Binding SendUri}" Margin="0,4,0,0"/>

                <BoxView HeightRequest="1" Color="Black" Margin="20,16"/>

                <Button Text="Transfer eDaler®" Command="{Binding TransferEDaler}"/>
                <Button Text="Buy eDaler®" Command="{Binding BuyEDaler}" Margin="0,8,0,0"/>
                <Button Text="Sell eDaler®" Command="{Binding SellEDaler}" Margin="0,4,0,0"/>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Transaction list -->
        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Events}"
                        SelectionMode="Single"
                        SelectionChanged="OnTransactionSelected">
            <CollectionView.Header>
                <Grid Padding="8,4" BackgroundColor="#DDDDDD">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Text="Transaction" FontAttributes="Bold"/>
                    <Label Grid.Column="1" Text="Timestamp" FontAttributes="Bold"/>
                    <Label Grid.Column="2" Text="Remote" FontAttributes="Bold"/>
                    <Label Grid.Column="3" Text="Change" FontAttributes="Bold"/>
                    <Label Grid.Column="4" Text="Balance" FontAttributes="Bold"/>
                    <Label Grid.Column="5" Text="Reserved" FontAttributes="Bold"/>
                    <Label Grid.Column="6" Text="Message" FontAttributes="Bold"/>
                </Grid>
            </CollectionView.Header>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="8,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Text="{Binding TransactionId}" FontSize="12" LineBreakMode="CharacterWrap"/>
                        <Label Grid.Column="1" Text="{Binding Timestamp, Converter={conv:DateTimeToString}}" FontSize="12"/>
                        <Label Grid.Column="2" Text="{Binding Remote}" FontSize="12"/>
                        <Label Grid.Column="3" Text="{Binding Change, Converter={conv:MoneyToString}}" FontSize="12" HorizontalOptions="End"/>
                        <Label Grid.Column="4" Text="{Binding Balance, Converter={conv:MoneyToString}}" FontSize="12" HorizontalOptions="End"/>
                        <Label Grid.Column="5" Text="{Binding Reserved, Converter={conv:MoneyToString}}" FontSize="12" HorizontalOptions="End"/>
                        <Label Grid.Column="6" Text="{Binding Message}" FontSize="12"/>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Selected transaction detail -->
          <Grid Grid.Row="2" Margin="16" IsVisible="{Binding SelectedItem, Converter={conv:VisibleIfNotNull}}"
              BindingContext="{Binding SelectedItem}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Label Grid.Column="0" Grid.Row="0" Text="Transaction ID:"/>
            <Entry Grid.Column="0" Grid.Row="1" Text="{Binding TransactionId, Mode=OneWay}" IsReadOnly="True" Margin="0,0,8,0"/>
            <Label Grid.Column="0" Grid.Row="2" Text="Timestamp:" Margin="0,8,0,0"/>
            <Entry Grid.Column="0" Grid.Row="3" Text="{Binding Timestamp, Mode=OneWay, Converter={conv:DateTimeToString}}" IsReadOnly="True" Margin="0,0,8,0"/>
            <Label Grid.Column="0" Grid.Row="4" Text="Remote party:" Margin="0,8,0,0"/>
            <Entry Grid.Column="0" Grid.Row="5" Text="{Binding Remote, Mode=OneWay}" IsReadOnly="True" Margin="0,0,8,0"/>

            <Label Grid.Column="1" Grid.Row="0" Text="Change:"/>
            <Entry Grid.Column="1" Grid.Row="1" Text="{Binding Change, Mode=OneWay, Converter={conv:MoneyToString}}" IsReadOnly="True" Margin="0,0,8,0"/>
            <Label Grid.Column="1" Grid.Row="2" Text="Balance:" Margin="0,8,0,0"/>
            <Entry Grid.Column="1" Grid.Row="3" Text="{Binding Balance, Mode=OneWay, Converter={conv:MoneyToString}}" IsReadOnly="True" Margin="0,0,8,0"/>

            <Label Grid.Column="2" Grid.Row="2" Text="Reserved:" Margin="0,8,0,0"/>
            <Entry Grid.Column="2" Grid.Row="3" Text="{Binding Reserved, Mode=OneWay, Converter={conv:MoneyToString}}" IsReadOnly="True"/>

            <Label Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="4" Text="Message:" Margin="0,8,0,0"/>
            <Entry Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="5" Text="{Binding Message, Mode=OneWay}" IsReadOnly="True"/>
        </Grid>
    </Grid>
</ContentPage>
