<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:conv="clr-namespace:LegalLabMaui.Converters"
             xmlns:events="clr-namespace:LegalLabMaui.Models.Events"
             x:Class="LegalLabMaui.Views.EventsPage"
             x:DataType="events:ObservableEventSink"
             Title="Events">
    <Grid Padding="24,20,24,28"
           RowDefinitions="Auto,*"
           RowSpacing="18">
         <Border Style="{StaticResource SectionCardStyle}">
             <VerticalStackLayout Spacing="6">
                  <Label Text="Event Feed"
                          Style="{StaticResource PageTitleStyle}"/>
                  <Label Text="Operational events, actors, and messages are listed chronologically with severity coloring preserved from the model."
                          Style="{StaticResource SectionCaptionStyle}"/>
             </VerticalStackLayout>
         </Border>

         <Border Grid.Row="1"
                  Style="{StaticResource SectionCardStyle}">
             <CollectionView ItemsSource="{Binding Events}"
                                SelectionMode="Single">
                  <CollectionView.ItemTemplate>
                      <DataTemplate x:DataType="events:LogItem">
                           <Border Style="{StaticResource CompactSectionCardStyle}"
                                    Margin="0,0,0,10"
                                    BackgroundColor="{Binding BackgroundColor}">
                                <VerticalStackLayout Spacing="8">
                                    <Grid ColumnDefinitions="Auto,Auto,Auto,*"
                                           ColumnSpacing="10">
                                         <Label Text="{Binding Time}"
                                                 TextColor="{Binding ForegroundColor}"
                                                 Style="{StaticResource DenseCellLabelStyle}"/>
                                         <Label Grid.Column="1"
                                                 Text="{Binding Type}"
                                                 TextColor="{Binding ForegroundColor}"
                                                 Style="{StaticResource DenseCellLabelStyle}"/>
                                         <Label Grid.Column="2"
                                                 Text="{Binding Level}"
                                                 TextColor="{Binding ForegroundColor}"
                                                 Style="{StaticResource DenseCellLabelStyle}"/>
                                         <Label Grid.Column="3"
                                                 Text="{Binding EventId}"
                                                 TextColor="{Binding ForegroundColor}"
                                                 Style="{StaticResource DenseCellLabelStyle}"
                                                 HorizontalOptions="End"/>
                                    </Grid>
                                    <Grid ColumnDefinitions="*,*"
                                           ColumnSpacing="12">
                                         <VerticalStackLayout Spacing="3">
                                             <Label Text="Object"
                                                     Style="{StaticResource FieldLabelStyle}"/>
                                             <Label Text="{Binding Object}"
                                                     TextColor="{Binding ForegroundColor}"
                                                     Style="{StaticResource DenseCellLabelStyle}"/>
                                         </VerticalStackLayout>
                                         <VerticalStackLayout Grid.Column="1"
                                                                 Spacing="3">
                                             <Label Text="Actor"
                                                     Style="{StaticResource FieldLabelStyle}"/>
                                             <Label Text="{Binding Actor}"
                                                     TextColor="{Binding ForegroundColor}"
                                                     Style="{StaticResource DenseCellLabelStyle}"/>
                                         </VerticalStackLayout>
                                    </Grid>
                                    <VerticalStackLayout Spacing="3">
                                         <Label Text="Message"
                                                 Style="{StaticResource FieldLabelStyle}"/>
                                         <Label Text="{Binding Message}"
                                                 TextColor="{Binding ForegroundColor}"
                                                 Style="{StaticResource DenseCellLabelStyle}"
                                                 LineBreakMode="WordWrap"/>
                                    </VerticalStackLayout>
                                </VerticalStackLayout>
                           </Border>
                      </DataTemplate>
                  </CollectionView.ItemTemplate>
             </CollectionView>
         </Border>
    </Grid>
</ContentPage>
