<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:conv="clr-namespace:LegalLabMaui.Converters"
             xmlns:controls="clr-namespace:LegalLabMaui.Controls"
             xmlns:legal="clr-namespace:LegalLabMaui.Models.Legal"
             xmlns:items="clr-namespace:LegalLabMaui.Models.Legal.Items"
             xmlns:standards="clr-namespace:LegalLabMaui.Models.Standards"
             x:Class="LegalLabMaui.Views.ContractsPage"
             x:Name="ContractsPageRoot"
             x:DataType="legal:ContractModel"
             Title="Contracts">
        <ContentPage.Resources>
                <Style x:Key="ContractsMutedCardStyle"
                       TargetType="Border"
                       BasedOn="{StaticResource CompactSectionCardStyle}">
                        <Setter Property="BackgroundColor"
                                Value="{AppThemeBinding Light={StaticResource SurfaceMuted}, Dark={StaticResource Gray800}}"/>
                </Style>

                <Style x:Key="ContractsContentCardStyle"
                       TargetType="Border"
                       BasedOn="{StaticResource CompactSectionCardStyle}">
                        <Setter Property="BackgroundColor"
                                Value="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource Gray950}}"/>
                </Style>

                <Style x:Key="ContractsErrorLabelStyle"
                       TargetType="Label"
                       BasedOn="{StaticResource SectionCaptionStyle}">
                        <Setter Property="TextColor"
                                Value="{AppThemeBinding Light={StaticResource Danger}, Dark=#FF9B9B}"/>
                        <Setter Property="FontSize"
                                Value="11"/>
                </Style>
        </ContentPage.Resources>
        <ScrollView>
                <VerticalStackLayout Style="{StaticResource PageStackStyle}">
                        <Border Style="{StaticResource SectionCardStyle}">
                                <VerticalStackLayout Spacing="6">
                                        <Label Text="Contracts"
                                               Style="{StaticResource PageTitleStyle}"/>
                                        <Label Text="Select templates, review live contracts, inspect signatures and attachments, and complete role-based actions from one workspace."
                                               Style="{StaticResource SectionCaptionStyle}"/>
                                </VerticalStackLayout>
                        </Border>

                        <Border Style="{StaticResource SectionCardStyle}">
                                <VerticalStackLayout Spacing="14">
                                        <Label Text="Selection and Actions"
                                               Style="{StaticResource SectionTitleStyle}"/>
                                        <VerticalStackLayout Spacing="12">
                                                <VerticalStackLayout Spacing="6">
                                                        <Label Text="Template"
                                                               Style="{StaticResource FieldLabelStyle}"/>
                                                        <Picker ItemsSource="{Binding Source={x:Reference ContractsPageRoot}, Path=Templates}"
                                                                ItemDisplayBinding="{Binding TemplateName, x:DataType=legal:TemplateReferenceModel}"
                                                                SelectedItem="{Binding Source={x:Reference ContractsPageRoot}, Path=SelectedTemplate}"/>
                                                </VerticalStackLayout>
                                                <VerticalStackLayout Spacing="6">
                                                        <Label Text="Existing Contract"
                                                               Style="{StaticResource FieldLabelStyle}"/>
                                                        <Picker ItemsSource="{Binding Source={x:Reference ContractsPageRoot}, Path=ExistingContracts}"
                                                                ItemDisplayBinding="{Binding ContractName, x:DataType=legal:ContractReferenceModel}"
                                                                SelectedItem="{Binding Source={x:Reference ContractsPageRoot}, Path=SelectedExistingContract}"/>
                                                </VerticalStackLayout>
                                                <VerticalStackLayout Spacing="6">
                                                        <Label Text="Language"
                                                               Style="{StaticResource FieldLabelStyle}"/>
                                                        <Picker ItemsSource="{Binding Languages}"
                                                                ItemDisplayBinding="{Binding Language, x:DataType=standards:Iso__639_1+Record}"
                                                                SelectedItem="{Binding SelectedLanguage}"/>
                                                </VerticalStackLayout>
                                        </VerticalStackLayout>

                                        <HorizontalStackLayout Spacing="10">
                                                <CheckBox IsChecked="{Binding AutoSignProposals}"/>
                                                <Label Text="Auto-sign contract proposals."
                                                       VerticalOptions="Center"/>
                                        </HorizontalStackLayout>

                                             <Label Text="{Binding Source={x:Reference ContractsPageRoot}, Path=TemplateSourceFeedback}"
                                                     Style="{StaticResource SectionCaptionStyle}"
                                                     LineBreakMode="WordWrap"/>

                                        <FlexLayout Wrap="Wrap"
                                                    Direction="Row">
                                                <Button Text="Create Contract"
                                                        Command="{Binding CreateContract}"/>
                                                <Button Text="Fetch Remote Template"
                                                        Clicked="OnFetchRemoteTemplateClicked"
                                                        Style="{StaticResource SecondaryButtonStyle}"/>
                                                <Button Text="Remove Template"
                                                        Command="{Binding RemoveTemplate}"
                                                        IsVisible="{Binding IsTemplate}"
                                                        Style="{StaticResource SecondaryButtonStyle}"/>
                                                <Button Text="Remove Contract"
                                                        Command="{Binding RemoveContract}"
                                                        IsVisible="{Binding IsContract}"
                                                        Style="{StaticResource DangerButtonStyle}"/>
                                        </FlexLayout>

                                        <Border Style="{StaticResource ContractsMutedCardStyle}">
                                                <VerticalStackLayout Spacing="4">
                                                        <Label Text="Create Contract Status"
                                                               Style="{StaticResource FieldLabelStyle}"/>
                                                        <Label Text="{Binding CreateContractFeedback}"
                                                               Style="{StaticResource SectionCaptionStyle}"
                                                               LineBreakMode="WordWrap"/>
                                                </VerticalStackLayout>
                                        </Border>
                                </VerticalStackLayout>
                        </Border>

                        <Border Style="{StaticResource SectionCardStyle}">
                                <VerticalStackLayout Spacing="14">
                                        <Label Text="Contract Summary"
                                               Style="{StaticResource SectionTitleStyle}"/>
                                        <VerticalStackLayout Spacing="14">
                                                <VerticalStackLayout Spacing="6">
                                                        <Label Text="Contract ID"
                                                               Style="{StaticResource FieldLabelStyle}"/>
                                                        <Entry Text="{Binding ContractId}"
                                                               IsReadOnly="True"/>
                                                </VerticalStackLayout>
                                                <VerticalStackLayout Spacing="8"
                                                                     BindableLayout.ItemsSource="{Binding GeneralInformation}">
                                                        <BindableLayout.ItemTemplate>
                                                                <DataTemplate x:DataType="items:GenInfo">
                                                                        <Border Style="{StaticResource ContractsMutedCardStyle}">
                                                                                <VerticalStackLayout Spacing="4">
                                                                                        <Label Text="{Binding Name}"
                                                                                               Style="{StaticResource FieldLabelStyle}"/>
                                                                                        <Label Text="{Binding Value}"
                                                                                               Style="{StaticResource DenseCellLabelStyle}"
                                                                                               LineBreakMode="WordWrap"/>
                                                                                </VerticalStackLayout>
                                                                        </Border>
                                                                </DataTemplate>
                                                        </BindableLayout.ItemTemplate>
                                                </VerticalStackLayout>
                                                <Border Style="{StaticResource ContractsMutedCardStyle}"
                                                        IsVisible="{Binding HasId}">
                                                        <VerticalStackLayout Spacing="8">
                                                                <Label Text="QR Access"
                                                                       Style="{StaticResource FieldLabelStyle}"/>
                                                                <Image Source="{Binding QrCodeUri}"
                                                                       WidthRequest="180"
                                                                       HeightRequest="180"
                                                                       HorizontalOptions="Center"
                                                                       IsVisible="{Binding HasId}"/>
                                                                <Label Text="Scan this code to open the contract from another device."
                                                                       Style="{StaticResource SectionCaptionStyle}"
                                                                       HorizontalTextAlignment="Center"
                                                                       IsVisible="{Binding HasId}"/>
                                                        </VerticalStackLayout>
                                                </Border>
                                        </VerticalStackLayout>
                                </VerticalStackLayout>
                        </Border>

                        <Border Style="{StaticResource SectionCardStyle}">
                                <VerticalStackLayout Spacing="14">
                                        <Label Text="Roles"
                                               Style="{StaticResource SectionTitleStyle}"/>
                                        <VerticalStackLayout Spacing="10"
                                                             BindableLayout.ItemsSource="{Binding Roles}">
                                                <BindableLayout.ItemTemplate>
                                                        <DataTemplate x:DataType="items:RoleInfo">
                                                                <Border Style="{StaticResource ContractsMutedCardStyle}">
                                                                        <VerticalStackLayout Spacing="10">
                                                                                <Label Text="{Binding Name}"
                                                                                       Style="{StaticResource FieldLabelStyle}"/>
                                                                                <Label Text="{Binding DescriptionAsText}"
                                                                                       Style="{StaticResource DenseCellLabelStyle}"
                                                                                       LineBreakMode="WordWrap"/>
                                                                                <Grid ColumnDefinitions="*,*,*"
                                                                                      ColumnSpacing="10">
                                                                                        <VerticalStackLayout Spacing="2">
                                                                                                <Label Text="Min"
                                                                                                       Style="{StaticResource FieldLabelStyle}"/>
                                                                                                <Label Text="{Binding MinCount}"
                                                                                                       Style="{StaticResource DenseCellLabelStyle}"/>
                                                                                        </VerticalStackLayout>
                                                                                        <VerticalStackLayout Grid.Column="1"
                                                                                                             Spacing="2">
                                                                                                <Label Text="Max"
                                                                                                       Style="{StaticResource FieldLabelStyle}"/>
                                                                                                <Label Text="{Binding MaxCount}"
                                                                                                       Style="{StaticResource DenseCellLabelStyle}"/>
                                                                                        </VerticalStackLayout>
                                                                                        <VerticalStackLayout Grid.Column="2"
                                                                                                             Spacing="2">
                                                                                                <Label Text="Revoke"
                                                                                                       Style="{StaticResource FieldLabelStyle}"/>
                                                                                                <Label Text="{Binding CanRevoke, Converter={conv:BooleanToYesNo}}"
                                                                                                       Style="{StaticResource DenseCellLabelStyle}"/>
                                                                                        </VerticalStackLayout>
                                                                                </Grid>
                                                                                <FlexLayout Wrap="Wrap"
                                                                                            Direction="Row">
                                                                                        <Button Text="Sign"
                                                                                                Command="{Binding SignAsRole}"
                                                                                                IsEnabled="{Binding CanBeSigned}"
                                                                                                Style="{StaticResource CompactButtonStyle}"/>
                                                                                        <Button Text="Propose"
                                                                                                Command="{Binding ProposeForRole}"
                                                                                                IsEnabled="{Binding CanBeSigned}"
                                                                                                Style="{StaticResource CompactButtonStyle}"/>
                                                                                </FlexLayout>
                                                                        </VerticalStackLayout>
                                                                </Border>
                                                        </DataTemplate>
                                                </BindableLayout.ItemTemplate>
                                        </VerticalStackLayout>
                                </VerticalStackLayout>
                        </Border>

                        <Border Style="{StaticResource SectionCardStyle}">
                                <VerticalStackLayout Spacing="14">
                                        <Label Text="Parts and Parameters"
                                               Style="{StaticResource SectionTitleStyle}"/>
                                        <VerticalStackLayout Spacing="18">
                                                <VerticalStackLayout Spacing="12">
                                                        <Label Text="Parts"
                                                               Style="{StaticResource FieldLabelStyle}"/>
                                                        <VerticalStackLayout Spacing="10"
                                                                             BindableLayout.ItemsSource="{Binding Parts}">
                                                                <BindableLayout.ItemTemplate>
                                                                        <DataTemplate x:DataType="items:PartInfo">
                                                                                <Border Style="{StaticResource ContractsMutedCardStyle}">
                                                                                        <VerticalStackLayout Spacing="10">
                                                                                                <VerticalStackLayout Spacing="2">
                                                                                                        <Label Text="Legal ID"
                                                                                                               Style="{StaticResource FieldLabelStyle}"/>
                                                                                                        <Label Text="{Binding LegalId}"
                                                                                                               Style="{StaticResource DenseCellLabelStyle}"
                                                                                                               LineBreakMode="CharacterWrap"/>
                                                                                                </VerticalStackLayout>
                                                                                                <VerticalStackLayout Spacing="4">
                                                                                                        <Label Text="Role"
                                                                                                               Style="{StaticResource FieldLabelStyle}"/>
                                                                                                        <Picker ItemsSource="{Binding Roles}"
                                                                                                                SelectedItem="{Binding Role}"
                                                                                                                FontSize="12"/>
                                                                                                </VerticalStackLayout>
                                                                                                <FlexLayout Wrap="Wrap"
                                                                                                            Direction="Row">
                                                                                                        <Button Text="Up"
                                                                                                                Command="{Binding MoveUp}"
                                                                                                                Style="{StaticResource CompactButtonStyle}"/>
                                                                                                        <Button Text="Down"
                                                                                                                Command="{Binding MoveDown}"
                                                                                                                Style="{StaticResource CompactButtonStyle}"/>
                                                                                                        <Button Text="Remove"
                                                                                                                Command="{Binding RemovePart}"
                                                                                                                Style="{StaticResource CompactButtonStyle}"/>
                                                                                                </FlexLayout>
                                                                                        </VerticalStackLayout>
                                                                                </Border>
                                                                        </DataTemplate>
                                                                </BindableLayout.ItemTemplate>
                                                        </VerticalStackLayout>
                                                        <Button Text="Add Part"
                                                                Command="{Binding AddPart}"
                                                                HorizontalOptions="Start"
                                                                WidthRequest="120"/>
                                                </VerticalStackLayout>

                                                <VerticalStackLayout Spacing="12">
                                                        <Label Text="Parameters"
                                                               Style="{StaticResource FieldLabelStyle}"/>
                                                        <VerticalStackLayout Spacing="10"
                                                                             BindableLayout.ItemsSource="{Binding Parameters}">
                                                                <BindableLayout.ItemTemplate>
                                                                        <DataTemplate x:DataType="items:ParameterInfo">
                                                                                <Border Style="{StaticResource ContractsMutedCardStyle}">
                                                                                        <VerticalStackLayout Spacing="8">
                                                                                                <Label Text="{Binding Name}"
                                                                                                       Style="{StaticResource FieldLabelStyle}"/>
                                                                                                <Entry Text="{Binding EditableValue}"
                                                                                                       IsEnabled="{Binding CanEditValue}"
                                                                                                       FontSize="12"/>
                                                                                                <Label Text="{Binding DescriptionAsText}"
                                                                                                       Style="{StaticResource DenseCellLabelStyle}"
                                                                                                       LineBreakMode="WordWrap"/>
                                                                                                             <Label Text="{Binding ErrorText}"
                                                                                                                     Style="{StaticResource ContractsErrorLabelStyle}"
                                                                                                       IsVisible="{Binding ErrorText, Converter={conv:VisibleIfNotNull}}"
                                                                                                       LineBreakMode="WordWrap"/>
                                                                                        </VerticalStackLayout>
                                                                                </Border>
                                                                        </DataTemplate>
                                                                </BindableLayout.ItemTemplate>
                                                        </VerticalStackLayout>
                                                </VerticalStackLayout>
                                        </VerticalStackLayout>
                                </VerticalStackLayout>
                        </Border>

                        <Border Style="{StaticResource SectionCardStyle}">
                                <VerticalStackLayout Spacing="12">
                                        <Label Text="Contract Content"
                                               Style="{StaticResource SectionTitleStyle}"/>
                                        <Label Text="Machine-readable content"
                                               Style="{StaticResource FieldLabelStyle}"/>
                                        <Editor x:Name="MachineReadableXmlEditor"
                                                Text="{Binding MachineReadable}"
                                                Style="{StaticResource MonoEditorStyle}"
                                                IsReadOnly="True"
                                                AutoSize="TextChanges"
                                                MinimumHeightRequest="220"/>
                                        <Label Text="Human-readable content"
                                               Style="{StaticResource FieldLabelStyle}"/>
                                        <Border Style="{StaticResource ContractsContentCardStyle}">
                                                <controls:MarkdownView Markdown="{Binding HumanReadableText}"/>
                                        </Border>
                                </VerticalStackLayout>
                        </Border>

                        <Border Style="{StaticResource SectionCardStyle}">
                                <VerticalStackLayout Spacing="14">
                                        <Label Text="Attachments"
                                               Style="{StaticResource SectionTitleStyle}"/>
                                        <VerticalStackLayout Spacing="10"
                                                             BindableLayout.ItemsSource="{Binding Attachments}">
                                                <BindableLayout.ItemTemplate>
                                                        <DataTemplate x:DataType="items:AttachmentInfo">
                                                                <Border Style="{StaticResource ContractsMutedCardStyle}">
                                                                        <VerticalStackLayout Spacing="8">
                                                                                <VerticalStackLayout Spacing="2">
                                                                                        <Label Text="Attachment"
                                                                                               Style="{StaticResource FieldLabelStyle}"/>
                                                                                        <Label Text="{Binding Id}"
                                                                                               Style="{StaticResource DenseCellLabelStyle}"
                                                                                               LineBreakMode="CharacterWrap"/>
                                                                                </VerticalStackLayout>
                                                                                <Grid ColumnDefinitions="*,*"
                                                                                      ColumnSpacing="12">
                                                                                        <VerticalStackLayout Spacing="2">
                                                                                                <Label Text="Filename"
                                                                                                       Style="{StaticResource FieldLabelStyle}"/>
                                                                                                <Label Text="{Binding FileName}"
                                                                                                       Style="{StaticResource DenseCellLabelStyle}"
                                                                                                       LineBreakMode="WordWrap"/>
                                                                                        </VerticalStackLayout>
                                                                                        <VerticalStackLayout Grid.Column="1"
                                                                                                             Spacing="2">
                                                                                                <Label Text="Type"
                                                                                                       Style="{StaticResource FieldLabelStyle}"/>
                                                                                                <Label Text="{Binding ContentType}"
                                                                                                       Style="{StaticResource DenseCellLabelStyle}"
                                                                                                       LineBreakMode="WordWrap"/>
                                                                                        </VerticalStackLayout>
                                                                                </Grid>
                                                                                <VerticalStackLayout Spacing="2">
                                                                                        <Label Text="Timestamp"
                                                                                               Style="{StaticResource FieldLabelStyle}"/>
                                                                                        <Label Text="{Binding Timestamp, Converter={conv:DateTimeToString}}"
                                                                                               Style="{StaticResource DenseCellLabelStyle}"/>
                                                                                </VerticalStackLayout>
                                                                                <FlexLayout Wrap="Wrap"
                                                                                            Direction="Row">
                                                                                        <Button Text="Download"
                                                                                                Command="{Binding DownloadAttachment}"
                                                                                                IsEnabled="{Binding CanDownloadAttachment}"
                                                                                                Style="{StaticResource CompactButtonStyle}"/>
                                                                                        <Button Text="Remove"
                                                                                                Command="{Binding RemoveAttachment}"
                                                                                                IsEnabled="{Binding CanRemoveAttachment}"
                                                                                                Style="{StaticResource CompactButtonStyle}"/>
                                                                                </FlexLayout>
                                                                        </VerticalStackLayout>
                                                                </Border>
                                                        </DataTemplate>
                                                </BindableLayout.ItemTemplate>
                                        </VerticalStackLayout>
                                        <Button Text="Upload Attachment"
                                                Command="{Binding UploadAttachment}"
                                                IsEnabled="{Binding CanUploadAttachment}"
                                                HorizontalOptions="Start"
                                                WidthRequest="160"/>
                                </VerticalStackLayout>
                        </Border>

                        <Border Style="{StaticResource SectionCardStyle}">
                                <VerticalStackLayout Spacing="14">
                                        <Label Text="Signatures"
                                               Style="{StaticResource SectionTitleStyle}"/>
                                        <Label Text="Client signatures"
                                               Style="{StaticResource FieldLabelStyle}"/>
                                             <VerticalStackLayout Spacing="10"
                                                                     BindableLayout.ItemsSource="{Binding ClientSignatures}">
                                                      <BindableLayout.ItemTemplate>
                                                                <DataTemplate x:DataType="items:ClientSignatureInfo">
                                                                         <Border Style="{StaticResource ContractsMutedCardStyle}">
                                                                                  <VerticalStackLayout Spacing="8">
                                                                                           <VerticalStackLayout Spacing="2">
                                                                                                    <Label Text="Network JID"
                                                                                                            Style="{StaticResource FieldLabelStyle}"/>
                                                                                                    <Label Text="{Binding BareJid}"
                                                                                                            Style="{StaticResource DenseCellLabelStyle}"
                                                                                                            LineBreakMode="CharacterWrap"/>
                                                                                           </VerticalStackLayout>
                                                                                           <VerticalStackLayout Spacing="2">
                                                                                                    <Label Text="Legal ID"
                                                                                                            Style="{StaticResource FieldLabelStyle}"/>
                                                                                                    <Label Text="{Binding LegalId}"
                                                                                                            Style="{StaticResource DenseCellLabelStyle}"
                                                                                                            LineBreakMode="CharacterWrap"/>
                                                                                           </VerticalStackLayout>
                                                                                           <Grid ColumnDefinitions="*,*,*"
                                                                                                  ColumnSpacing="12">
                                                                                                    <VerticalStackLayout Spacing="2">
                                                                                                             <Label Text="Role"
                                                                                                                     Style="{StaticResource FieldLabelStyle}"/>
                                                                                                             <Label Text="{Binding Role}"
                                                                                                                     Style="{StaticResource DenseCellLabelStyle}"/>
                                                                                                    </VerticalStackLayout>
                                                                                                    <VerticalStackLayout Grid.Column="1"
                                                                                                                            Spacing="2">
                                                                                                             <Label Text="Timestamp"
                                                                                                                     Style="{StaticResource FieldLabelStyle}"/>
                                                                                                             <Label Text="{Binding Timestamp, Converter={conv:DateTimeToString}}"
                                                                                                                     Style="{StaticResource DenseCellLabelStyle}"/>
                                                                                                    </VerticalStackLayout>
                                                                                                    <VerticalStackLayout Grid.Column="2"
                                                                                                                            Spacing="2">
                                                                                                             <Label Text="Transferable"
                                                                                                                     Style="{StaticResource FieldLabelStyle}"/>
                                                                                                             <Label Text="{Binding Transferable, Converter={conv:BooleanToYesNo}}"
                                                                                                                     Style="{StaticResource DenseCellLabelStyle}"/>
                                                                                                    </VerticalStackLayout>
                                                                                           </Grid>
                                                                                           <VerticalStackLayout Spacing="2">
                                                                                                    <Label Text="Signature"
                                                                                                            Style="{StaticResource FieldLabelStyle}"/>
                                                                                                    <Label Text="{Binding Signature, Converter={conv:ToBase64}}"
                                                                                                            Style="{StaticResource MonoLabelStyle}"
                                                                                                            LineBreakMode="CharacterWrap"/>
                                                                                           </VerticalStackLayout>
                                                                                  </VerticalStackLayout>
                                                                         </Border>
                                                                </DataTemplate>
                                                      </BindableLayout.ItemTemplate>
                                             </VerticalStackLayout>

                                        <Label Text="Server signatures"
                                               Style="{StaticResource FieldLabelStyle}"/>
                                        <VerticalStackLayout Spacing="10"
                                                             BindableLayout.ItemsSource="{Binding ServerSignatures}">
                                                <BindableLayout.ItemTemplate>
                                                        <DataTemplate x:DataType="items:ServerSignatureInfo">
                                                                <Border Style="{StaticResource ContractsMutedCardStyle}">
                                                                        <VerticalStackLayout Spacing="6">
                                                                                <Label Text="{Binding Timestamp, Converter={conv:DateTimeToString}}"
                                                                                       Style="{StaticResource FieldLabelStyle}"/>
                                                                                <Label Text="{Binding Signature, Converter={conv:ToBase64}}"
                                                                                       Style="{StaticResource MonoLabelStyle}"
                                                                                       LineBreakMode="CharacterWrap"/>
                                                                        </VerticalStackLayout>
                                                                </Border>
                                                        </DataTemplate>
                                                </BindableLayout.ItemTemplate>
                                        </VerticalStackLayout>
                                </VerticalStackLayout>
                        </Border>
                </VerticalStackLayout>
        </ScrollView>
</ContentPage>
