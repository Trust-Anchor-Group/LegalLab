<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:conv="clr-namespace:LegalLabMaui.Converters"
             xmlns:tokens="clr-namespace:LegalLabMaui.Models.Tokens"
             xmlns:details="clr-namespace:LegalLabMaui.Models.Tokens.Details"
             xmlns:nf="clr-namespace:NeuroFeatures;assembly=NeuroFeatures"
             x:Class="LegalLabMaui.Views.TokensPage"
             x:DataType="tokens:TokensModel"
             Title="Tokens">
        <ScrollView>
                <VerticalStackLayout Style="{StaticResource PageStackStyle}">
                        <Border Style="{StaticResource SectionCardStyle}">
                                <VerticalStackLayout Spacing="6">
                                        <Label Text="Tokens"
                                               Style="{StaticResource PageTitleStyle}"/>
                                        <Label Text="Inspect token inventory, current totals, event history, and item-level details in one review flow."
                                               Style="{StaticResource SectionCaptionStyle}"/>
                                </VerticalStackLayout>
                        </Border>

                        <Border Style="{StaticResource SectionCardStyle}">
                                <VerticalStackLayout Spacing="14">
                                        <Label Text="Totals"
                                               Style="{StaticResource SectionTitleStyle}"/>
                                        <CollectionView ItemsSource="{Binding Totals}"
                                                        HeightRequest="150">
                                                <CollectionView.Header>
                                                        <Grid Style="{StaticResource DenseHeaderGridStyle}">
                                                                <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="120"/>
                                                                        <ColumnDefinition Width="80"/>
                                                                        <ColumnDefinition Width="160"/>
                                                                </Grid.ColumnDefinitions>
                                                                <Label Grid.Column="0"
                                                                       Text="Currency"
                                                                       Style="{StaticResource DenseHeaderLabelStyle}"/>
                                                                <Label Grid.Column="1"
                                                                       Text="Count"
                                                                       Style="{StaticResource DenseHeaderLabelStyle}"/>
                                                                <Label Grid.Column="2"
                                                                       Text="Total Value"
                                                                       Style="{StaticResource DenseHeaderLabelStyle}"/>
                                                        </Grid>
                                                </CollectionView.Header>
                                                <CollectionView.ItemTemplate>
                                                        <DataTemplate x:DataType="nf:TokenTotal">
                                                                <Grid Padding="10,6">
                                                                        <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="120"/>
                                                                                <ColumnDefinition Width="80"/>
                                                                                <ColumnDefinition Width="160"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <Label Grid.Column="0"
                                                                               Text="{Binding Currency}"
                                                                               Style="{StaticResource DenseCellLabelStyle}"/>
                                                                        <Label Grid.Column="1"
                                                                               Text="{Binding NrTokens, Converter={conv:ToString}}"
                                                                               Style="{StaticResource DenseCellLabelStyle}"
                                                                               HorizontalOptions="End"/>
                                                                        <Label Grid.Column="2"
                                                                               Text="{Binding Total, Converter={conv:MoneyToString}}"
                                                                               Style="{StaticResource DenseCellLabelStyle}"
                                                                               HorizontalOptions="End"/>
                                                                </Grid>
                                                        </DataTemplate>
                                                </CollectionView.ItemTemplate>
                                        </CollectionView>
                                </VerticalStackLayout>
                        </Border>

                        <Border Style="{StaticResource SectionCardStyle}">
                                <VerticalStackLayout Spacing="14">
                                        <Label Text="Token Inventory"
                                               Style="{StaticResource SectionTitleStyle}"/>
                                        <CollectionView ItemsSource="{Binding Tokens}"
                                                        SelectionMode="Single"
                                                        SelectionChanged="OnTokenSelected"
                                                        HeightRequest="360">
                                                <CollectionView.Header>
                                                        <Grid Style="{StaticResource DenseHeaderGridStyle}">
                                                                <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="140"/>
                                                                        <ColumnDefinition Width="120"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="90"/>
                                                                        <ColumnDefinition Width="100"/>
                                                                        <ColumnDefinition Width="90"/>
                                                                </Grid.ColumnDefinitions>
                                                                <Label Grid.Column="0"
                                                                       Text="Friendly Name"
                                                                       Style="{StaticResource DenseHeaderLabelStyle}"/>
                                                                <Label Grid.Column="1"
                                                                       Text="Category"
                                                                       Style="{StaticResource DenseHeaderLabelStyle}"/>
                                                                <Label Grid.Column="2"
                                                                       Text="ID"
                                                                       Style="{StaticResource DenseHeaderLabelStyle}"/>
                                                                <Label Grid.Column="3"
                                                                       Text="Expires"
                                                                       Style="{StaticResource DenseHeaderLabelStyle}"/>
                                                                <Label Grid.Column="4"
                                                                       Text="Value"
                                                                       Style="{StaticResource DenseHeaderLabelStyle}"/>
                                                                <Label Grid.Column="5"
                                                                       Text="Visibility"
                                                                       Style="{StaticResource DenseHeaderLabelStyle}"/>
                                                        </Grid>
                                                </CollectionView.Header>
                                                <CollectionView.ItemTemplate>
                                                        <DataTemplate x:DataType="tokens:TokenModel">
                                                                <Grid Padding="10,6"
                                                                      ColumnSpacing="10">
                                                                        <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="140"/>
                                                                                <ColumnDefinition Width="120"/>
                                                                                <ColumnDefinition Width="*"/>
                                                                                <ColumnDefinition Width="90"/>
                                                                                <ColumnDefinition Width="100"/>
                                                                                <ColumnDefinition Width="90"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <Label Grid.Column="0"
                                                                               Text="{Binding FriendlyName}"
                                                                               Style="{StaticResource DenseCellLabelStyle}"/>
                                                                        <Label Grid.Column="1"
                                                                               Text="{Binding Category}"
                                                                               Style="{StaticResource DenseCellLabelStyle}"/>
                                                                        <Label Grid.Column="2"
                                                                               Text="{Binding TokenId}"
                                                                               Style="{StaticResource DenseCellLabelStyle}"
                                                                               LineBreakMode="CharacterWrap"/>
                                                                        <Label Grid.Column="3"
                                                                               Text="{Binding Expires, Converter={conv:DateToXmlString}}"
                                                                               Style="{StaticResource DenseCellLabelStyle}"/>
                                                                        <Label Grid.Column="4"
                                                                               Text="{Binding Value, Converter={conv:MoneyToString}}"
                                                                               Style="{StaticResource DenseCellLabelStyle}"
                                                                               HorizontalOptions="End"/>
                                                                        <Label Grid.Column="5"
                                                                               Text="{Binding Visibility, Converter={conv:ToString}}"
                                                                               Style="{StaticResource DenseCellLabelStyle}"/>
                                                                </Grid>
                                                        </DataTemplate>
                                                </CollectionView.ItemTemplate>
                                        </CollectionView>
                                </VerticalStackLayout>
                        </Border>

                        <Border Style="{StaticResource SectionCardStyle}"
                                IsVisible="{Binding SelectedToken, Converter={conv:VisibleIfNotNull}}">
                                <VerticalStackLayout Spacing="14">
                                        <Label Text="Selected Token Details"
                                               Style="{StaticResource SectionTitleStyle}"/>
                                        <CollectionView ItemsSource="{Binding SelectedToken.Details}"
                                                        HeightRequest="220">
                                                <CollectionView.Header>
                                                        <Grid Style="{StaticResource DenseHeaderGridStyle}">
                                                                <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="180"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>
                                                                <Label Grid.Column="0"
                                                                       Text="Property"
                                                                       Style="{StaticResource DenseHeaderLabelStyle}"/>
                                                                <Label Grid.Column="1"
                                                                       Text="Value"
                                                                       Style="{StaticResource DenseHeaderLabelStyle}"/>
                                                        </Grid>
                                                </CollectionView.Header>
                                                <CollectionView.ItemTemplate>
                                                        <DataTemplate x:DataType="tokens:TokenDetail">
                                                                <Grid Padding="10,6"
                                                                      ColumnSpacing="10">
                                                                        <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="180"/>
                                                                                <ColumnDefinition Width="*"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <Label Grid.Column="0"
                                                                               Text="{Binding Name}"
                                                                               Style="{StaticResource DenseCellLabelStyle}"/>
                                                                        <Label Grid.Column="1"
                                                                               Text="{Binding Value}"
                                                                               Style="{StaticResource DenseCellLabelStyle}"
                                                                               LineBreakMode="WordWrap"/>
                                                                </Grid>
                                                        </DataTemplate>
                                                </CollectionView.ItemTemplate>
                                        </CollectionView>
                                </VerticalStackLayout>
                        </Border>

                        <Border Style="{StaticResource SectionCardStyle}"
                                IsVisible="{Binding Events, Converter={conv:VisibleIfNotNull}}">
                                <VerticalStackLayout Spacing="14">
                                        <Label Text="Selected Token Event History"
                                               Style="{StaticResource SectionTitleStyle}"/>
                                        <CollectionView ItemsSource="{Binding Events}"
                                                        HeightRequest="220">
                                                <CollectionView.Header>
                                                        <Grid Style="{StaticResource DenseHeaderGridStyle}">
                                                                <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="160"/>
                                                                        <ColumnDefinition Width="70"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="90"/>
                                                                        <ColumnDefinition Width="90"/>
                                                                </Grid.ColumnDefinitions>
                                                                <Label Grid.Column="0"
                                                                       Text="Timestamp"
                                                                       Style="{StaticResource DenseHeaderLabelStyle}"/>
                                                                <Label Grid.Column="1"
                                                                       Text="Personal"
                                                                       Style="{StaticResource DenseHeaderLabelStyle}"/>
                                                                <Label Grid.Column="2"
                                                                       Text="Message"
                                                                       Style="{StaticResource DenseHeaderLabelStyle}"/>
                                                                <Label Grid.Column="3"
                                                                       Text="Value"
                                                                       Style="{StaticResource DenseHeaderLabelStyle}"/>
                                                                <Label Grid.Column="4"
                                                                       Text="Owner"
                                                                       Style="{StaticResource DenseHeaderLabelStyle}"/>
                                                        </Grid>
                                                </CollectionView.Header>
                                                <CollectionView.ItemTemplate>
                                                        <DataTemplate x:DataType="details:TokenEventDetail">
                                                                <Grid Padding="10,6"
                                                                      ColumnSpacing="10">
                                                                        <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="160"/>
                                                                                <ColumnDefinition Width="70"/>
                                                                                <ColumnDefinition Width="*"/>
                                                                                <ColumnDefinition Width="90"/>
                                                                                <ColumnDefinition Width="90"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <Label Grid.Column="0"
                                                                               Text="{Binding Timestamp, Converter={conv:DateTimeToString}}"
                                                                               Style="{StaticResource DenseCellLabelStyle}"/>
                                                                        <Label Grid.Column="1"
                                                                               Text="{Binding Personal}"
                                                                               Style="{StaticResource DenseCellLabelStyle}"/>
                                                                        <Label Grid.Column="2"
                                                                               Text="{Binding Message}"
                                                                               Style="{StaticResource DenseCellLabelStyle}"
                                                                               LineBreakMode="WordWrap"/>
                                                                        <Label Grid.Column="3"
                                                                               Text="{Binding Value}"
                                                                               Style="{StaticResource DenseCellLabelStyle}"/>
                                                                        <Label Grid.Column="4"
                                                                               Text="{Binding Owner}"
                                                                               Style="{StaticResource DenseCellLabelStyle}"/>
                                                                </Grid>
                                                        </DataTemplate>
                                                </CollectionView.ItemTemplate>
                                        </CollectionView>
                                </VerticalStackLayout>
                        </Border>
                </VerticalStackLayout>
        </ScrollView>
</ContentPage>
