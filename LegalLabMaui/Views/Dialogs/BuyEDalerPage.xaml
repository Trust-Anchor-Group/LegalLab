<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:dialogs="clr-namespace:LegalLabMaui.Views.Dialogs"
             x:Class="LegalLabMaui.Views.Dialogs.BuyEDalerPage"
             x:DataType="dialogs:BuyEDalerModel"
             Title="Buy eDaler®">
        <ScrollView>
                <VerticalStackLayout Style="{StaticResource PageStackStyle}">
                        <Border Style="{StaticResource SectionCardStyle}">
                                <VerticalStackLayout Spacing="6">
                                        <Label Text="Buy eDaler®"
                                               Style="{StaticResource SectionTitleStyle}"/>
                                        <Label Text="Choose a service provider and define the purchase amount."
                                               Style="{StaticResource SectionCaptionStyle}"/>
                                </VerticalStackLayout>
                        </Border>

                        <Border Style="{StaticResource SectionCardStyle}">
                                <VerticalStackLayout Spacing="10">
                                        <Label Text="Service Provider"
                                               Style="{StaticResource FieldLabelStyle}"/>
                                        <CollectionView ItemsSource="{Binding ServiceProviders}"
                                                        SelectionMode="Single"
                                                        SelectedItem="{Binding SelectedServiceProvider}"
                                                        HeightRequest="180">
                                                <CollectionView.ItemsLayout>
                                                        <LinearItemsLayout Orientation="Horizontal"
                                                                           ItemSpacing="8"/>
                                                </CollectionView.ItemsLayout>
                                                <CollectionView.ItemTemplate>
                                                        <DataTemplate x:DataType="dialogs:ServiceProviderModel">
                                                                <Border Stroke="{StaticResource BorderSubtleBrush}"
                                                                        StrokeThickness="1"
                                                                        BackgroundColor="{StaticResource SurfaceMuted}"
                                                                        StrokeShape="RoundRectangle 16"
                                                                        Padding="12"
                                                                        Margin="0,0,8,0">
                                                                        <VerticalStackLayout WidthRequest="100"
                                                                                             HeightRequest="100"
                                                                                             Spacing="8"
                                                                                             VerticalOptions="Center"
                                                                                             HorizontalOptions="Center">
                                                                                <Image Source="{Binding IconUrl}"
                                                                                       WidthRequest="{Binding IconWidth}"
                                                                                       HeightRequest="{Binding IconHeight}"
                                                                                       HorizontalOptions="Center"
                                                                                       VerticalOptions="Center"/>
                                                                        </VerticalStackLayout>
                                                                </Border>
                                                        </DataTemplate>
                                                </CollectionView.ItemTemplate>
                                        </CollectionView>
                                </VerticalStackLayout>
                        </Border>

                        <Border Style="{StaticResource SectionCardStyle}">
                                <Grid ColumnDefinitions="*,*"
                                      RowDefinitions="Auto,Auto"
                                      ColumnSpacing="16"
                                      RowSpacing="12">
                                        <Label Grid.Row="0"
                                               Grid.Column="0"
                                               Text="Amount"
                                               Style="{StaticResource FieldLabelStyle}"/>
                                        <Label Grid.Row="0"
                                               Grid.Column="1"
                                               Text="Currency"
                                               Style="{StaticResource FieldLabelStyle}"/>
                                        <Entry Grid.Row="1"
                                               Grid.Column="0"
                                               x:Name="Amount"
                                               Text="{Binding Amount}"
                                               Keyboard="Numeric"/>
                                        <Entry Grid.Row="1"
                                               Grid.Column="1"
                                               x:Name="Currency"
                                               Text="{Binding Currency}"/>
                                </Grid>
                        </Border>

                        <HorizontalStackLayout HorizontalOptions="End"
                                               Spacing="12">
                                <Button Text="Cancel"
                                        Command="{Binding Cancel}"
                                        Style="{StaticResource SecondaryButtonStyle}"/>
                                <Button Text="Buy"
                                        Command="{Binding Buy}"/>
                        </HorizontalStackLayout>
                </VerticalStackLayout>
        </ScrollView>
</ContentPage>
