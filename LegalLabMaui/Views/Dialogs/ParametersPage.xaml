<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:legal="clr-namespace:LegalLabMaui.Models.Legal"
             x:Class="LegalLabMaui.Views.Dialogs.ParametersPage"
             x:DataType="legal:ContractParametersModel"
             Title="Parameters">
    <Grid Padding="24,20,24,24"
          RowDefinitions="Auto,*,Auto"
          RowSpacing="18">
        <Border Style="{StaticResource SectionCardStyle}">
            <VerticalStackLayout Spacing="6">
                <Label Text="Contract Parameters"
                       Style="{StaticResource PageTitleStyle}"/>
                <Label Text="Review required inputs, complete missing values, and confirm when parameter validation is satisfied."
                       Style="{StaticResource SectionCaptionStyle}"/>
            </VerticalStackLayout>
        </Border>

        <Border Grid.Row="1"
                Style="{StaticResource SectionCardStyle}">
            <ScrollView>
                <VerticalStackLayout x:Name="ParametersPanel"
                                     Spacing="12">
                    <!-- Parameters are added programmatically -->
                </VerticalStackLayout>
            </ScrollView>
        </Border>

        <HorizontalStackLayout Grid.Row="2"
                               HorizontalOptions="End"
                               Spacing="12">
            <Button Text="Cancel"
                    WidthRequest="110"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Clicked="CancelButton_Clicked"/>
            <Button Text="OK"
                    WidthRequest="110"
                    IsEnabled="{Binding ParametersOk}"
                    Clicked="OkButton_Clicked"/>
        </HorizontalStackLayout>
    </Grid>
</ContentPage>
