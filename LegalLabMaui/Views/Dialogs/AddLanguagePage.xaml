<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:dialogs="clr-namespace:LegalLabMaui.Views.Dialogs"
             xmlns:standards="clr-namespace:LegalLabMaui.Models.Standards"
             x:Class="LegalLabMaui.Views.Dialogs.AddLanguagePage"
             x:DataType="dialogs:AddLanguageModel"
             Title="Add Language">
    <VerticalStackLayout Padding="16"
            Spacing="12"
            VerticalOptions="Center">
        <Label Text="Select Language to add:"
                FontAttributes="Bold"/>
        <Picker x:Name="LanguageCombo"
                ItemsSource="{Binding Languages}"
                ItemDisplayBinding="{Binding Language, x:DataType=standards:Iso__639_1+Record}"
                SelectedItem="{Binding SelectedLanguageRecord}"/>
        <HorizontalStackLayout HorizontalOptions="Center"
                Spacing="16">
            <Button Text="Add"
                    Command="{Binding Add}"
                    WidthRequest="100"/>
            <Button Text="Cancel"
                    Command="{Binding Cancel}"
                    WidthRequest="100"/>
        </HorizontalStackLayout>
    </VerticalStackLayout>
</ContentPage>
