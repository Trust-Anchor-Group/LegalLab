<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:dialogs="clr-namespace:LegalLabMaui.Views.Dialogs"
             xmlns:standards="clr-namespace:LegalLabMaui.Models.Standards"
             x:Class="LegalLabMaui.Views.Dialogs.AddLanguagePage"
             x:DataType="dialogs:AddLanguageModel"
             Title="Add Language">
        <ScrollView>
                <VerticalStackLayout Style="{StaticResource PageStackStyle}">
                        <Border Style="{StaticResource SectionCardStyle}">
                                <VerticalStackLayout Spacing="6">
                                        <Label Text="Add Language"
                                               Style="{StaticResource SectionTitleStyle}"/>
                                        <Label Text="Choose an additional language for the active workflow."
                                               Style="{StaticResource SectionCaptionStyle}"/>
                                </VerticalStackLayout>
                        </Border>

                        <Border Style="{StaticResource SectionCardStyle}">
                                <VerticalStackLayout Spacing="10">
                                        <Label Text="Language"
                                               Style="{StaticResource FieldLabelStyle}"/>
                                        <Picker x:Name="LanguageCombo"
                                                ItemsSource="{Binding Languages}"
                                                ItemDisplayBinding="{Binding Language, x:DataType=standards:Iso__639_1+Record}"
                                                SelectedItem="{Binding SelectedLanguageRecord}"/>
                                </VerticalStackLayout>
                        </Border>

                        <HorizontalStackLayout HorizontalOptions="End"
                                               Spacing="12">
                                <Button Text="Cancel"
                                        Command="{Binding Cancel}"
                                        Style="{StaticResource SecondaryButtonStyle}"/>
                                <Button Text="Add"
                                        Command="{Binding Add}"/>
                        </HorizontalStackLayout>
                </VerticalStackLayout>
        </ScrollView>
</ContentPage>
