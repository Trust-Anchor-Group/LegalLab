<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LegalLabMaui.Views.Dialogs.AddLanguagePage"
             Title="Add Language">
    <VerticalStackLayout Padding="16" Spacing="12" VerticalOptions="Center">
        <Label Text="Select Language to add:" FontAttributes="Bold"/>
        <Picker x:Name="LanguageCombo"
                ItemsSource="{Binding Languages}"
                ItemDisplayBinding="{Binding Language}"
                SelectedItem="{Binding SelectedLanguageRecord}"/>
        <HorizontalStackLayout HorizontalOptions="Center" Spacing="16">
            <Button Text="Add" Command="{Binding Add}" WidthRequest="100"/>
            <Button Text="Cancel" Command="{Binding Cancel}" WidthRequest="100"/>
        </HorizontalStackLayout>
    </VerticalStackLayout>
</ContentPage>
