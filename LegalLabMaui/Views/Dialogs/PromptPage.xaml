<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:dialogs="clr-namespace:LegalLabMaui.Views.Dialogs"
             x:Class="LegalLabMaui.Views.Dialogs.PromptPage"
             x:DataType="dialogs:PromptModel"
             Title="{Binding Title}">
        <ScrollView>
                <VerticalStackLayout Style="{StaticResource PageStackStyle}">
                        <Border Style="{StaticResource SectionCardStyle}">
                                <VerticalStackLayout Spacing="6">
                                        <Label Text="{Binding Title}"
                                               Style="{StaticResource SectionTitleStyle}"/>
                                        <Label Text="{Binding Label}"
                                               Style="{StaticResource SectionCaptionStyle}"/>
                                </VerticalStackLayout>
                        </Border>

                        <Border Style="{StaticResource SectionCardStyle}">
                                <VerticalStackLayout Spacing="10">
                                        <Label Text="Input"
                                               Style="{StaticResource FieldLabelStyle}"/>
                                        <Entry Text="{Binding Text}"
                                               x:Name="UserInput"/>
                                </VerticalStackLayout>
                        </Border>

                        <HorizontalStackLayout HorizontalOptions="End"
                                               Spacing="12">
                                <Button Text="{Binding CancelText}"
                                        Command="{Binding Cancel}"
                                        Style="{StaticResource SecondaryButtonStyle}"/>
                                <Button Text="{Binding OkText}"
                                        Command="{Binding Ok}"/>
                        </HorizontalStackLayout>
                </VerticalStackLayout>
        </ScrollView>
</ContentPage>
