<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:dialogs="clr-namespace:LegalLabMaui.Views.Dialogs"
             x:Class="LegalLabMaui.Views.Dialogs.AddXmlNotePage"
             x:DataType="dialogs:AddXmlNoteModel"
             Title="Add XML Note">
        <Grid RowDefinitions="*,Auto">
                <ScrollView Grid.Row="0">
                        <VerticalStackLayout Style="{StaticResource PageStackStyle}">
                                <Border Style="{StaticResource SectionCardStyle}">
                                        <VerticalStackLayout Spacing="6">
                                                <Label Text="Add XML Note"
                                                       Style="{StaticResource SectionTitleStyle}"/>
                                                <Label Text="Paste the XML fragment you want to attach to the current document."
                                                       Style="{StaticResource SectionCaptionStyle}"/>
                                        </VerticalStackLayout>
                                </Border>

                                <Border Style="{StaticResource SectionCardStyle}">
                                        <VerticalStackLayout Spacing="10">
                                                <Label Text="XML Content"
                                                       Style="{StaticResource FieldLabelStyle}"/>
                                                <Editor x:Name="XmlEditor"
                                                        Text="{Binding XmlInput}"
                                                        Style="{StaticResource MonoEditorStyle}"
                                                        AutoSize="TextChanges"
                                                        MinimumHeightRequest="240"
                                                        TextChanged="XmlEditor_TextChanged"/>
                                        </VerticalStackLayout>
                                </Border>
                        </VerticalStackLayout>
                </ScrollView>

                <HorizontalStackLayout Grid.Row="1"
                                       HorizontalOptions="End"
                                       Spacing="12"
                                       Padding="24,0,24,24">
                        <Button Text="Cancel"
                                Command="{Binding Cancel}"
                                Style="{StaticResource SecondaryButtonStyle}"/>
                        <Button Text="Add"
                                Command="{Binding Add}"/>
                </HorizontalStackLayout>
        </Grid>
</ContentPage>
