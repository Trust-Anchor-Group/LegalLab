<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:LegalLabMaui.Controls"
             xmlns:views="clr-namespace:LegalLabMaui.Views"
             x:Class="LegalLabMaui.Views.ReportPage"
             x:DataType="views:ReportPage"
             Title="Report">
    <ScrollView x:Name="ReportScrollView">
        <VerticalStackLayout x:Name="ReportPanel"
                             Style="{StaticResource PageStackStyle}">
            <Border Style="{StaticResource SectionCardStyle}">
                <VerticalStackLayout Spacing="6">
                    <Label Text="Report Viewer"
                           Style="{StaticResource PageTitleStyle}"/>
                    <Label Text="Reports opened from tokens or tools are rendered here as a reading surface with stable spacing and line wrapping."
                           Style="{StaticResource SectionCaptionStyle}"/>
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource SectionCardStyle}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Rendered Report"
                           Style="{StaticResource SectionTitleStyle}"/>
                    <Border Style="{StaticResource CompactSectionCardStyle}"
                            BackgroundColor="{StaticResource Surface}">
                        <controls:MarkdownView Markdown="{Binding ReportText}"/>
                    </Border>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
