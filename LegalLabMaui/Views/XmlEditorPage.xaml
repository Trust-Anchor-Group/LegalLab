<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:conv="clr-namespace:LegalLabMaui.Converters"
             xmlns:xmleditor="clr-namespace:LegalLabMaui.Models.XmlEditor"
             x:Class="LegalLabMaui.Views.XmlEditorPage"
             x:DataType="xmleditor:XmlEditorModel"
             Title="XML Editor">
    <Grid Padding="24,20,24,28"
          RowDefinitions="Auto,Auto,*"
          RowSpacing="18">
        <Border Style="{StaticResource SectionCardStyle}">
            <VerticalStackLayout Spacing="6">
                <Label Text="XML Workspace"
                       Style="{StaticResource PageTitleStyle}"/>
                <Label Text="Edit XML directly and keep a synchronized visualization panel visible during document work."
                       Style="{StaticResource SectionCaptionStyle}"/>
            </VerticalStackLayout>
        </Border>

        <Border Grid.Row="1"
                Style="{StaticResource SectionCardStyle}">
            <FlexLayout Wrap="Wrap"
                        Direction="Row"
                        AlignItems="Center">
                <Button Text="New"
                        Command="{Binding NewDocument}"
                        WidthRequest="82"/>
                <Button Text="Load"
                        Command="{Binding LoadDocument}"
                        WidthRequest="82"
                        Style="{StaticResource SecondaryButtonStyle}"/>
                <Button Text="Save"
                        Command="{Binding SaveDocument}"
                        IsEnabled="{Binding Changed}"
                        WidthRequest="82"
                        Style="{StaticResource SecondaryButtonStyle}"/>
                <Label Text="Zoom"
                       Margin="16,0,0,0"
                       VerticalOptions="Center"
                       Style="{StaticResource FieldLabelStyle}"/>
                <Picker x:Name="ZoomPicker"
                        WidthRequest="150"
                        SelectedItem="{Binding SelectedZoomText}">
                    <Picker.Items>
                        <x:String>Fit to size</x:String>
                        <x:String>10%</x:String>
                        <x:String>25%</x:String>
                        <x:String>50%</x:String>
                        <x:String>75%</x:String>
                        <x:String>90%</x:String>
                        <x:String>100%</x:String>
                        <x:String>110%</x:String>
                        <x:String>125%</x:String>
                        <x:String>150%</x:String>
                        <x:String>200%</x:String>
                    </Picker.Items>
                </Picker>
            </FlexLayout>
        </Border>

        <Grid Grid.Row="2"
              ColumnDefinitions="*,*"
              ColumnSpacing="18">
            <Border Grid.Column="0"
                    Style="{StaticResource SectionCardStyle}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="XML Document"
                           Style="{StaticResource SectionTitleStyle}"/>
                    <Editor x:Name="XmlEditor"
                            Text="{Binding Xml}"
                            Style="{StaticResource MonoEditorStyle}"
                            AutoSize="TextChanges"
                            HorizontalOptions="Fill"
                            VerticalOptions="FillAndExpand"
                            MinimumHeightRequest="420"/>
                </VerticalStackLayout>
            </Border>

            <Border Grid.Column="1"
                    Style="{StaticResource SectionCardStyle}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Visualization"
                           Style="{StaticResource SectionTitleStyle}"/>
                    <ScrollView x:Name="VisualizationViewer">
                        <Label Text="{Binding VisualizationText}"
                               Padding="4"
                               FontSize="{Binding ZoomFontSize}"
                               LineBreakMode="WordWrap"/>
                    </ScrollView>
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
